{
  "name": "web-pdm-core",
  "version": "2.0.1",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && cp src/public-types.d.ts dist/index.d.ts",
    "dev": "vite build --watch",
    "publish-npm:patch": "npm run build ; npm version patch && npm publish --registry=https://registry.npmjs.org && cnpm sync web-pdm-core",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "ahooks": "^3.9.7",
    "classnames": "^2.5.1",
    "lodash-es": "^4.18.1",
    "mobx": "^6.16.1",
    "mobx-keystone": "^1.22.0",
    "mobx-react": "^9.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
