{
  "name": "web-pdm-core",
  "version": "2.0.1",
  "description": "Core runtime and public types for the web-pdm ER diagram workspace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lusess123/web-pdm.git",
    "directory": "packages/web-pdm-core"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && cp src/public-types.d.ts dist/index.d.ts",
    "dev": "vite build --watch",
    "prepublishOnly": "corepack pnpm test && corepack pnpm typecheck && corepack pnpm build",
    "publish-npm:patch": "corepack pnpm build && npm version patch && corepack pnpm publish --registry=https://registry.npmjs.org && cnpm sync web-pdm-core",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "mobx": "^6.16.1",
    "mobx-keystone": "^1.22.0",
    "mobx-react": "^9.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
