{
  "name": "web-pdm",
  "version": "0.4.0",
  "description": "A lightweight, embeddable React ER diagram workspace powered by G6 5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lusess123/web-pdm.git",
    "directory": "packages/web-pdm-lib"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && cp src/public-types.d.ts dist/index.d.ts",
    "dev": "vite build --watch",
    "prepublishOnly": "corepack pnpm test && corepack pnpm typecheck && corepack pnpm build",
    "release:next": "corepack pnpm publish --tag next --access public --no-git-checks",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "lucide-react": "^1.24.0",
    "web-pdm-core": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
