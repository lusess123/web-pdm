{
  "name": "web-pdm-doc",
  "version": "0.0.1",
  "private": true,
  "description": "A lightweight ER diagram library and documentation site",
  "license": "MIT",
  "scripts": {
    "build": "corepack pnpm build-lib && corepack pnpm docs:build",
    "build:site": "rspress build",
    "build:watch": "corepack pnpm --parallel --filter web-pdm-core --filter web-pdm dev",
    "build-lib": "corepack pnpm --filter web-pdm-core build && corepack pnpm --filter web-pdm build",
    "deploy:cloudflare": "corepack pnpm build:site && wrangler deploy",
    "deploy:cloudflare:dry-run": "corepack pnpm build:site && wrangler deploy --dry-run",
    "dev": "rspress dev",
    "docs:build": "corepack pnpm build:site",
    "lint": "npm run lint:es && npm run lint:css",
    "lint:css": "stylelint \"packages/*/src/**/*.{css,less,scss}\"",
    "lint:es": "eslint \"{docs,packages,test}/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "corepack pnpm test && corepack pnpm build-lib",
    "start": "corepack pnpm dev",
    "test": "vitest run",
    "test:browser": "node test/browser-smoke.mjs",
    "test:exports": "node test/package-exports.mjs",
    "test:watch": "vitest",
    "typecheck": "corepack pnpm typecheck:workspace && corepack pnpm typecheck:public",
    "typecheck:public": "corepack pnpm build-lib && tsc --ignoreConfig --noEmit --skipLibCheck --module esnext --moduleResolution bundler test/public-types.ts",
    "typecheck:workspace": "tsc --noEmit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "web-pdm": "workspace:*",
    "web-pdm-core": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@rsbuild/plugin-less": "^2.0.1",
    "@rsbuild/plugin-sass": "^2.0.1",
    "@rspress/core": "^2.0.17",
    "@rspress/plugin-preview": "^2.0.17",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.13.0"
  }
}
