{
  "name": "web-pdm-doc",
  "version": "0.0.1",
  "description": "A lightweight ER diagram library and documentation site",
  "license": "MIT",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build-lib && pnpm docs:build",
    "build:site": "rspress build",
    "build:watch": "pnpm --parallel --filter web-pdm-core --filter web-pdm dev",
    "build-lib": "pnpm --filter web-pdm-core build && pnpm --filter web-pdm build",
    "dev": "rspress dev",
    "docs:build": "pnpm build:site",
    "lint": "npm run lint:es && npm run lint:css",
    "lint:css": "stylelint \"packages/web-pdm-lib/src/**/*.{css,less,scss}\"",
    "lint:es": "eslint \"{docs,packages,test}/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm test && pnpm build-lib",
    "start": "pnpm dev",
    "test": "vitest run",
    "test:browser": "node test/browser-smoke.mjs",
    "test:exports": "node test/package-exports.mjs",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter web-pdm-core typecheck && pnpm typecheck:public",
    "typecheck:public": "pnpm build-lib && tsc --ignoreConfig --noEmit --skipLibCheck --module esnext --moduleResolution bundler test/public-types.ts"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "web-pdm": "workspace:*",
    "web-pdm-core": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@rsbuild/plugin-less": "^2.0.1",
    "@rsbuild/plugin-sass": "^2.0.1",
    "@rspress/core": "^2.0.17",
    "@rspress/plugin-preview": "^2.0.17",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": []
}
