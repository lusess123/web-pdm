{
  "compilerOptions": {
    "strict": false,
    "declaration": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "paths": {
      "web-pdm": ["./packages/web-pdm-lib/src"],
      "web-pdm-core": ["./packages/web-pdm-core/src"]
    }
  },
  "include": ["packages/**/*", "docs/**/*", "rspress.config.ts"]
}
